# ── SecureGate Environment Variables ──
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/securegate

# NextAuth
NEXTAUTH_SECRET=        # Generate with: openssl rand -base64 32
NEXTAUTH_URL=http://localhost:3000

# Password hashing
BCRYPT_ROUNDS=10

# Email — required for sending emails. Get your API key at https://resend.com
RESEND_API_KEY=
# No custom domain? Use Resend's built-in test sender (onboarding@resend.dev).
# Note: emails can only be delivered to the email on your Resend account.
# With a verified domain, change to: "SecureGate <noreply@yourdomain.com>"
EMAIL_FROM="SecureGate <onboarding@resend.dev>"

# SMTP Fallback (Used if RESEND_API_KEY is not set)
# You can use a free service like Ethereal (https://ethereal.email/) for testing
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
# App
NODE_ENV=development
